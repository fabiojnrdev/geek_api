# =============================================================================
# GEEK STORE — .env.example
# =============================================================================
# Como usar:
#   cp .env.example .env
# Depois edite o .env com seus valores reais.
# NUNCA commite o .env — apenas este .env.example vai ao git.
# =============================================================================

# =============================================================================
# BACKEND (FastAPI)
# =============================================================================

# --- Aplicação ---
APP_NAME="Geek Store API"
APP_VERSION="1.0.0"
DEBUG=false

# --- Banco de Dados ---
# Desenvolvimento (SQLite — sem configuração extra):
DATABASE_URL="sqlite:///./geek_store.db"
# Produção (PostgreSQL):
# DATABASE_URL="postgresql://seu-usuario:sua-senha@seu-host:5432/nome-do-banco"

# --- Segurança JWT ---
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="sua-chave-secreta-gerada-com-secrets-token-hex-32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Desenvolvimento:
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]'
# Produção (substitua pela URL real do seu frontend):
# CORS_ORIGINS='["https://seuapp.seudominio.com"]'

# =============================================================================
# FRONTEND (React / Vite)
# Todas as variáveis DEVEM ter prefixo VITE_ para ficarem
# acessíveis no browser via import.meta.env.VITE_*
# =============================================================================

# --- API ---
# Desenvolvimento:
VITE_API_BASE_URL="http://sua-url/api"
# Produção (substitua pela URL real do seu backend):
# VITE_API_BASE_URL="https://api.seudominio.com/api"

# --- App ---
VITE_APP_NAME="Geek Store"
VITE_APP_VERSION="1.0.0"

# --- HTTP ---
# Timeout das requisições em milissegundos
VITE_REQUEST_TIMEOUT=10000

# --- Dev ---
VITE_ENABLE_DEVTOOLS=true

# =============================================================================
# DEPLOY (Railway / Render / Docker)
# =============================================================================

# Porta do servidor (usada pelo Render/Railway via $PORT)
# PORT=8000

# Nível de log do Uvicorn
# LOG_LEVEL="info"