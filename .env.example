# =============================================================================
# GEEK STORE — ENVIRONMENT VARIABLES
# =============================================================================
# Copie este arquivo para .env na raiz do projeto (backend/) e para frontend/.env
# NUNCA commite o .env com valores reais. Este arquivo é o .env definitivo.

# =============================================================================
# BACKEND (FastAPI)
# =============================================================================

# --- Aplicação ---
APP_NAME="Geek Store API"
APP_VERSION="1.0.0"
DEBUG=false                          # true apenas em desenvolvimento local

# --- Banco de Dados ---
# Desenvolvimento (SQLite):
DATABASE_URL="sqlite:///./geek_store.db"

# Produção (PostgreSQL — descomente e preencha):
# DATABASE_URL="postgresql://usuario:senha@host:5432/geek_store_db"

# --- Segurança JWT ---
# ⚠️  TROQUE esta chave antes de ir para produção.
# Gere uma nova com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="TROQUE_ESTA_CHAVE_EM_PRODUCAO_use_secrets_token_hex_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Em desenvolvimento, aceita as portas padrão do Vite e CRA.
# Em produção, coloque apenas a URL do seu frontend (sem barra no final).
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]'
# Produção:
# CORS_ORIGINS='["https://geekstore.seudominio.com"]'

# --- Upload de Imagens (se implementar futuramente) ---
# MAX_UPLOAD_SIZE_MB=5
# ALLOWED_EXTENSIONS="jpg,jpeg,png,webp"

# =============================================================================
# FRONTEND (React / Vite)
# Variáveis prefixadas com VITE_ são expostas ao bundle do navegador.
# =============================================================================

# URL base da API — aponta para o backend FastAPI
VITE_API_BASE_URL="http://localhost:8000/api"

# Em produção:
# VITE_API_BASE_URL="https://geekstore-api.seudominio.com/api"

# Nome da aplicação (exibido na UI)
VITE_APP_NAME="Geek Store"
VITE_APP_VERSION="1.0.0"

# Timeout de requisições HTTP (ms)
VITE_REQUEST_TIMEOUT=10000

# =============================================================================
# DEPLOY (Railway / Render / Docker)
# =============================================================================

# Porta do servidor ASGI (usada pelo Render/Railway via $PORT)
# PORT=8000

# Nível de log do Uvicorn: "critical" | "error" | "warning" | "info" | "debug" | "trace"
# LOG_LEVEL="info"